{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/config/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/ideas/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/products/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/chat/?$",
			"dest": "_render"
		},
		{
			"src": "^/founder/?$",
			"dest": "_render"
		},
		{
			"src": "^/ideas/?$",
			"dest": "_render"
		},
		{
			"src": "^/products/?$",
			"dest": "_render"
		},
		{
			"src": "^/socials/?$",
			"dest": "_render"
		},
		{
			"src": "^/works/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}